{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch XD (MinGW 64-bit Debug)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/bin/XD.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "C:\\MinGWx64\\bin\\gdb.exe",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "Build Debug (MinGW 64-bit)",
            "postDebugTask": "Clear All"
        },
        {
            "name": "Run build File",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/_cmake/build_windows_debug.bat",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/_cmake/",
            "environment": [],
            "externalConsole": true,
            "MIMode": "gdb"
        }
    ]
}